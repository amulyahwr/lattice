{
  "manifest_version": 3,
  "name": "Lattice",
  "version": "0.1.0",
  "description": "Save selected text from any page to your local Lattice memory.",
  "permissions": ["contextMenus", "storage", "notifications"],
  "host_permissions": ["http://localhost:7337/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lattice"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
